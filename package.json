{
  "name": "bogatyi-kurier-pro",
  "version": "1.0.0",
  "description": "Богатый курьер Pro — JARVIS-style PC cleaner",
  "main": "main.js",
  "author": "DmitriyDzhambek",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron\"",
    "build": "vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "lucide-react": "^0.468.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "wait-on": "^9.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^39.2.7",
    "electron-builder": "^26.15.3",
    "vite": "^7.3.0"
  },
  "build": {
    "appId": "com.dmitriydzhambek.bogatiykurierpro",
    "productName": "Богатый курьер Pro",
    "directories": {
      "output": "dist-installer",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "package.json",
      "dist-react/**/*",
      "public/**/*",
      "backgroung.jpg"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Богатый курьер Pro"
    }
  }
}
